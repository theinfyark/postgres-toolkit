{
  "name": "postgres-toolkit",
  "version": "1.0.0",
  "description": "PostgreSQL helper with connection pool, retry, transactions, health checks, query logging, and connection stats.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src",
    "types",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --test tests/db.test.js",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "postgres",
    "postgresql",
    "pg",
    "pool",
    "transaction",
    "retry",
    "database",
    "sql"
  ],
  "author": "anilachary",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theinfyark/postgres-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/theinfyark/postgres-toolkit/issues"
  },
  "homepage": "https://github.com/theinfyark/postgres-toolkit#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "pg": "^8.16.0"
  },
  "types": "./types/index.d.ts",
  "sideEffects": false,
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/anilachary"
  }
}
